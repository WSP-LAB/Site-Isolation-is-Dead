new file mode 100644
index 0000000..ec56bb3
--- /dev/null
+++ b/chrome-extension/src/background/agent/agents/verifier.ts
@@ -0,0 +1,19 @@
+import { z } from 'zod';
+
+// Define Zod schema for planner output
+export const verifierOutputSchema = z.object({
+  decision: z.enum(["ALLOW", "BLOCK"]),
+  risk_score: z.union([
+    z.number().int().min(0).max(100),
+    z.string().transform((val) => {
+      const num = Number(val);
+      if (!isNaN(num) && num >= 0 && num <= 100) return num;
+      throw new Error("Invalid risk_score value");
+    }),
+  ]),
+  mismatch_level: z.enum(["NONE", "MINOR", "MAJOR"]),
+  rule_hits: z.string(),
+  evidence: z.string(),
+  short_rationale: z.string().max(200), // limit length to ensure brevity
+});
+
